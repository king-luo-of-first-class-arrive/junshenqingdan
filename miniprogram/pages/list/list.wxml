<!-- 清单详情页 — 任务列表含 CRUD -->
<view class="page">
  <view class="task-item {{task.done ? 'done' : ''}}"
    wx:for="{{tasks}}" wx:key="_id" wx:for-item="task">

    <view class="task-check" data-id="{{task._id}}" data-done="{{task.done}}"
      bindtap="onToggleTask">
      <text>{{task.done ? '✓' : '○'}}</text>
    </view>

    <view class="task-body" data-id="{{task._id}}" bindtap="onEditTask">
      <text class="task-title">{{task.title}}</text>
      <text class="task-note" wx:if="{{task.note}}">{{task.note}}</text>
    </view>

    <text class="task-del" data-id="{{task._id}}" catchtap="onDeleteTask">✕</text>
  </view>

  <view class="add-row" bindtap="onAddTap" wx:if="{{!adding}}">
    <text class="add-icon">+</text>
    <text class="add-text">添加任务</text>
  </view>

  <view class="add-form" wx:if="{{adding}}">
    <input class="input-field" placeholder="任务标题" value="{{newTaskTitle}}"
      bindinput="onTaskInput" focus />
    <view class="form-actions">
      <button class="btn-plain small" bindtap="onCancelAdd">取消</button>
      <button class="btn-primary small" bindtap="onConfirmAdd">添加</button>
    </view>
  </view>
</view>

<!-- 编辑任务弹层 -->
<view class="modal-overlay" wx:if="{{editingTask}}">
  <view class="modal-content">
    <text class="modal-title">编辑任务</text>
    <input class="input-field" placeholder="标题" value="{{editTitle}}"
      bindinput="onEditTitleInput" />
    <textarea class="input-field textarea" placeholder="备注" value="{{editNote}}"
      bindinput="onEditNoteInput" />
    <view class="modal-actions">
      <button class="btn-plain" bindtap="onCancelEdit">取消</button>
      <button class="btn-primary" bindtap="onSaveEdit">保存</button>
    </view>
  </view>
</view>
