.space-row {
  display: flex;
  align-items: center;
}

.space-info { flex: 1; }

.space-name {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.space-type {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.detail-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: 8rpx;
}

.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border: 2rpx dashed #ddd;
  background: transparent;
}

.create-icon {
  font-size: 40rpx;
  color: #ccc;
  margin-right: 12rpx;
}

.create-text { font-size: 28rpx; color: #999; }

.join-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: #fff;
}

.join-icon {
  font-size: 36rpx;
  color: var(--color-primary);
  margin-right: 12rpx;
}

.join-text { font-size: 28rpx; color: var(--color-primary); }

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.modal-actions button {
  flex: 1;
  margin: 0;
}
