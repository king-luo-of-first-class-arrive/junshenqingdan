.page { padding-bottom: 120rpx; }

.header {
  background: #fff;
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.space-switcher {
  display: flex;
  align-items: center;
}

.space-name {
  font-size: 36rpx;
  font-weight: 700;
}

.switch-icon {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.date-label {
  font-size: 28rpx;
  color: #999;
}

.list-group {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.list-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.list-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
}

.list-count {
  font-size: 24rpx;
  color: #999;
  background: #f0f0f0;
  border-radius: 20rpx;
  padding: 2rpx 12rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f8f8f8;
}

.task-item.done .task-title {
  text-decoration: line-through;
  color: #ccc;
}

.task-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--color-primary);
  margin-right: 16rpx;
}

.task-title {
  flex: 1;
  font-size: 28rpx;
}

.add-task-row {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  color: #999;
}

.add-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #ccc;
}

.add-text { font-size: 26rpx; }

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #ccc;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.modal-actions button {
  flex: 1;
  margin: 0;
}

.fab {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
  z-index: 50;
}

.fab-text {
  color: #fff;
  font-size: 56rpx;
  line-height: 1;
}
