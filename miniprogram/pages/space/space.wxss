.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.section-sub { font-size: 24rpx; color: #999; }

.debug-id { font-size: 20rpx; color: #ccc; word-break: break-all; }

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.add-btn { font-size: 26rpx; color: var(--color-primary); }

.list-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.list-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.list-name { flex: 1; font-size: 28rpx; }
.arrow { font-size: 32rpx; color: #ccc; }

.invite-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.invite-code {
  flex: 1;
  background: #f8f8f8;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

button.small {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.member-name { flex: 1; font-size: 28rpx; }
.member-role { font-size: 24rpx; color: #999; margin-right: 16rpx; }
.remove-btn { font-size: 24rpx; color: var(--color-danger); }

button.danger {
  color: var(--color-danger);
  border-color: var(--color-danger);
}

.empty-hint {
  text-align: center;
  padding: 32rpx 0;
  color: #ccc;
  font-size: 26rpx;
}

.colors {
  display: flex;
  gap: 24rpx;
  margin: 20rpx 0;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.color-dot.active {
  border-color: #333;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.modal-actions button {
  flex: 1;
  margin: 0;
}
